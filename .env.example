# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Saathi - The Invisible Elder
NEXT_PUBLIC_API_URL=http://localhost:5000

# OpenAI API (for AI companion features)
OPENAI_API_KEY=your_openai_api_key_here

# Database
MONGODB_URI=mongodb://localhost:27017/saathi

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Email Configuration (for medicine reminders)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password

# Twilio (for SMS reminders - optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Voice Recognition (optional)
SPEECH_API_KEY=your_speech_api_key
